# Copy to .env and fill in real values

# Server
APP_ENV=development
LOG_LEVEL=INFO

# CORS — comma-separated origins for the Streamlit / Next.js UI
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# LLM (RAG) — placeholder for whichever provider Ryan picks (Ollama / OpenAI / etc.)
LLM_PROVIDER=ollama
LLM_URL=http://localhost:11434
LLM_MODEL=llama3.1

# Vector store — placeholder for RAG (e.g. Chroma, Qdrant, pgvector)
VECTOR_DB_URL=

# Data paths (mounted from ../data via docker-compose)
DATA_DIR=/data
